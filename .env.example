# MallPulse — environment variable template
# Copy to .env, fill in values. Never commit .env.

# Fivetran (Day 8) — get from Fivetran → Settings → API Configuration
FIVETRAN_API_KEY=your_fivetran_api_key_here
FIVETRAN_API_SECRET=your_fivetran_api_secret_here
# Paste your Cloud SQL Postgres connector ID from the Fivetran UI connector URL
FIVETRAN_CONNECTOR_ID=your_connector_id_here

# Cloud SQL Postgres (Day 4)
PG_HOST=your_cloud_sql_public_ip
PG_USER=postgres
PG_PWD=your_postgres_password
PG_PORT=5432
PG_DB=mallpulse

# Looker Studio (Day 11) — paste embed URL after building dashboard
# Format: https://lookerstudio.google.com/embed/reporting/<REPORT_ID>/page/<PAGE_ID>
LOOKER_STUDIO_URL=https://lookerstudio.google.com/embed/reporting/YOUR_REPORT_ID/page/YOUR_PAGE_ID

# GCP
GCP_PROJECT=mallpulse-hackathon
GCP_REGION=us-central1
BQ_DATASET=mallpulse_core

# ADK — use Vertex AI (Gemini on GCP) instead of Gemini developer API
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=mallpulse-hackathon
GOOGLE_CLOUD_LOCATION=us-central1
